# 模擬租戶後端設定（複製成 .env 後修改；server.mjs 會自動載入同目錄 .env）

# 此模擬網站的埠
PORT=4000

# OA Agent 來源（載入 widget.js 與聊天面板 iframe 的網域＝client 服務）
OA_ORIGIN=http://localhost:3000

# API（server）對外來源。前後端分開部署時必填，指向 server 網域（≠ OA_ORIGIN）。
# 例：OA_API_ORIGIN=https://oa-agent-server.zeabur.app
# 同網域 / 本機 dev proxy 留空即可（預設沿用 OA_ORIGIN）。
OA_API_ORIGIN=

# 租戶公開金鑰（建租戶時取得）
TENANT_PK=pk_3dc8a9721d103efb0972aac2c0ef79d237698f765178fc6a

# 租戶 SSO 密鑰（必須等於該租戶建立時設定的 ssoSecret）
TENANT_SSO_SECRET=test-secret1234567890

# 模擬「對方系統目前登入的使用者」
DEMO_USER_ID=hyweb
DEMO_USER_NAME=測試員
