# Webhook 接收端設定（複製成 .env；server 會自動載入）

PORT=4300
OA_ORIGIN=http://localhost:3000
# 本服務對外可被 OA 連到的網址（OA 會 POST 到這）
RECEIVER_URL=http://localhost:4300/webhook
# 防重放容許誤差（秒），0 = 關閉時間檢查
TOLERANCE_SEC=300

# ── 取得驗章密鑰：二選一 ──
# A) 直接填你登記端點時拿到的密鑰
WEBHOOK_SECRET=

# B) 留空 WEBHOOK_SECRET，改填以下兩項 → 啟動時自動向 OA 管理 API 登記本服務並取回 secret
ADMIN_API_KEY=
TENANT_ID=
