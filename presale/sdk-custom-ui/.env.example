# SDK 自訂 UI 測試網站設定（複製成 .env；server.mjs 會自動載入同目錄 .env）

PORT=4200
OA_ORIGIN=http://localhost:3000

# 租戶公開金鑰；注意：此租戶的 allowedOrigins 必須包含 http://localhost:4200（或 *）
# 因為 SDK 是從本頁面「跨網域」直接呼叫 OA，會經過 CORS 檢查（與 widget 在 iframe 內同源不同）
TENANT_PK=pk_3dc8a9721d103efb0972aac2c0ef79d237698f765178fc6a

# 租戶 SSO 密鑰（須等於建租戶時設定的 ssoSecret）
TENANT_SSO_SECRET=test-secret1234567890

# 模擬「對方系統目前登入的使用者」
DEMO_USER_ID=hyweb
DEMO_USER_NAME=測試員
