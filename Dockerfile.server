# OA Agent — server 服務（Express API）
# build context = repo 根目錄（monorepo workspaces 需從 root 安裝才解析得到 @oa-agent/*）

# ---- build stage：裝全部依賴 + 編譯 TS ----
FROM node:20-slim AS build
WORKDIR /app

# 先複製各 workspace 的 manifest，最大化 layer cache
COPY package.json package-lock.json ./
COPY shared/package.json ./shared/
COPY ui/package.json ./ui/
COPY server/package.json ./server/
COPY client/package.json ./client/
# --include=dev：Zeabur build 環境預設 NODE_ENV=production，會讓 npm 跳過 devDependencies
# （tsc / tsc-alias 在 devDeps），強制裝進來才 build 得了
RUN npm ci --include=dev

COPY . .
RUN npm run build -w server

# ---- runtime stage：只裝 production 依賴 + 帶編譯產物 ----
FROM node:20-slim AS runtime
WORKDIR /app
ENV NODE_ENV=production
# Zeabur 的 Git/Dockerfile 服務只路由「一個」埠＝Dockerfile EXPOSE。
# server 讀 env.PORT，所以讓 PORT 與 EXPOSE 對齊到 3000，兩邊一致才路由得到。
# 註：若 Zeabur 後台另外注入了 PORT，會蓋掉這裡的 ENV；那就把後台的 PORT 也設成 3000。
ENV PORT=3000

COPY package.json package-lock.json ./
COPY shared/package.json ./shared/
COPY ui/package.json ./ui/
COPY server/package.json ./server/
COPY client/package.json ./client/
RUN npm ci --omit=dev

COPY --from=build /app/server/dist ./server/dist
COPY --from=build /app/schemas ./schemas

EXPOSE 3000
CMD ["node", "server/dist/index.js"]
