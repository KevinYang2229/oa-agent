{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "formId": "business-trip-domestic",
  "title": "國內出差報銷申請",
  "type": "object",
  "properties": {
    "onBehalf": {
      "type": "boolean",
      "description": "代人申請（填單人是否替他人申請）"
    },
    "applicant": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "申請人，格式：姓名(工號)"
    },
    "company": {
      "type": "string",
      "enum": ["凌網", "全球", "知識", "資訊", "萬耀", "元華", "方集"],
      "description": "所屬公司"
    },
    "purpose": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "出差目的"
    },
    "tripDate": {
      "type": "string",
      "format": "date",
      "description": "出差日期 YYYY-MM-DD"
    },
    "routeFrom": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "路程起點，例如 台北辦公室"
    },
    "routeTo": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "路程終點，例如 新竹辦公室"
    },
    "taxiFee": {
      "type": "number",
      "minimum": 0,
      "description": "交通費－計程車（元）"
    },
    "hsrFee": {
      "type": "number",
      "minimum": 0,
      "description": "交通費－高鐵（元）"
    },
    "transitFee": {
      "type": "number",
      "minimum": 0,
      "description": "交通費－大眾運輸（元）"
    },
    "privateCarKm": {
      "type": "number",
      "minimum": 0,
      "description": "私車公用－公里數"
    },
    "privateCarFee": {
      "type": "number",
      "minimum": 0,
      "description": "私車公用－金額（元）"
    },
    "lodgingFee": {
      "type": "number",
      "minimum": 0,
      "description": "住宿費（元）"
    },
    "mealFee": {
      "type": "number",
      "minimum": 0,
      "description": "膳雜費（元）"
    },
    "parkingFee": {
      "type": "number",
      "minimum": 0,
      "description": "停車費（元）"
    },
    "carpoolFee": {
      "type": "number",
      "minimum": 0,
      "description": "共乘費（元）"
    },
    "carpoolMembers": {
      "type": "string",
      "maxLength": 200,
      "description": "共乘人員（選填）"
    },
    "subtotal": {
      "type": "number",
      "minimum": 0,
      "description": "小計（員工支出費用小計，元）"
    },
    "hsrCarbon": {
      "type": "number",
      "minimum": 0,
      "description": "高鐵碳排放 kg.CO2e；依實際出差填寫單程或來回數據（例如新竹↔台北來回為 2.13*2=4.26）"
    },
    "attachments": {
      "type": "array",
      "description": "附件清單（單據、證明文件等）；僅存 metadata，檔案內容由後端附件儲存區保管",
      "maxItems": 10,
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "後端產生的附件識別碼" },
          "name": { "type": "string", "description": "原始檔名" },
          "mime": { "type": "string", "description": "MIME 類型" },
          "size": { "type": "number", "description": "檔案大小（bytes）" },
          "description": { "type": "string", "maxLength": 200, "description": "附件說明" }
        },
        "required": ["id", "name"]
      }
    }
  },
  "additionalProperties": false
}
