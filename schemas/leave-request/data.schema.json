{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "formId": "leave-request",
  "title": "請假單",
  "type": "object",
  "properties": {
    "onBehalf": {
      "type": "boolean",
      "description": "代人申請（是否替他人申請）"
    },
    "applicant": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "申請人，格式：姓名(工號)"
    },
    "deputy": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "職務代理人，格式：姓名(工號)"
    },
    "deputyAllForms": {
      "type": "boolean",
      "description": "同時代理所有表單"
    },
    "leaveType": {
      "type": "string",
      "enum": ["annual", "personal", "sick", "official", "funeral", "marriage"],
      "description": "請假類型 / leave type"
    },
    "startDate": {
      "type": "string",
      "format": "date",
      "description": "開始日期 YYYY-MM-DD"
    },
    "startTime": {
      "type": "string",
      "pattern": "^\\d{2}:\\d{2}$",
      "description": "開始時間 HH:mm"
    },
    "endDate": {
      "type": "string",
      "format": "date",
      "description": "結束日期 YYYY-MM-DD"
    },
    "endTime": {
      "type": "string",
      "pattern": "^\\d{2}:\\d{2}$",
      "description": "結束時間 HH:mm"
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "請假事由"
    },
    "attachments": {
      "type": "array",
      "description": "附件清單（證明文件等）；僅存 metadata，檔案內容由後端附件儲存區保管",
      "maxItems": 10,
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "後端產生的附件識別碼" },
          "name": { "type": "string", "description": "原始檔名" },
          "mime": { "type": "string", "description": "MIME 類型" },
          "size": { "type": "number", "description": "檔案大小（bytes）" },
          "description": { "type": "string", "maxLength": 200, "description": "附件說明" }
        },
        "required": ["id", "name"]
      }
    }
  },
  "additionalProperties": false
}
