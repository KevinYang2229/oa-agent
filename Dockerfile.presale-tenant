# OA Agent — presale demo「widge-tenant」（模擬租戶網站 + SSO 免登入）
# build context = repo 根目錄（server.mjs 透過 monorepo workspaces 解析 @oa-agent/sdk）
#
# 為何用 tsx 啟動：server.mjs 會 `import '@oa-agent/sdk/server'`，而該 export 指向 raw TS
# （sdk/src/server.ts），純 node 無法直接載入；tsx（server 的 devDependency）可即時轉譯。

FROM node:20-slim AS runtime
WORKDIR /app
# 注意：不要設 NODE_ENV=production，否則 npm ci 會略過 devDependencies（tsx 在其中）

# 先複製所有 workspace 的 manifest（npm workspaces 安裝需要全部 package.json 存在），最大化 layer cache
COPY package.json package-lock.json ./
COPY shared/package.json ./shared/
COPY ui/package.json ./ui/
COPY sdk/package.json ./sdk/
COPY server/package.json ./server/
COPY client/package.json ./client/
COPY admin/package.json ./admin/
# --include=dev：取得 tsx（server devDep）；同時帶進 sdk → jsonwebtoken 供簽 token
RUN npm ci --include=dev

COPY . .

# Zeabur 的 Dockerfile 服務只路由「一個」埠＝EXPOSE；server.mjs 讀 env.PORT，兩邊對齊到 8080。
# 若 Zeabur 後台另外注入了 PORT，會蓋掉這裡的 ENV；那就把後台 PORT 也設成 8080。
ENV PORT=8080
EXPOSE 8080
CMD ["npx", "tsx", "presale/widge-tenant/server.mjs"]
