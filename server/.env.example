# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app_dev?schema=public"

# JWT
JWT_ACCESS_SECRET=replace_with_strong_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_strong_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS（第一方來源，如前端 SPA；逗號分隔多個，* 全放行）
CORS_ORIGIN=http://localhost:5173

# 多租戶：預設租戶（未帶 API Key 的舊 widget 落點）允許嵌入的網域
# * = 全放行（維持改造前行為，向後相容）；或逗號分隔網域收緊，如 https://a.com,https://b.com
DEFAULT_TENANT_ORIGINS=*

# 管理 API 主控密鑰（建立租戶 / 簽發金鑰 / 登記 webhook / 查用量）
# 留空 = 停用管理 API（預設關閉以策安全）；啟用請填一段夠長的隨機字串（如 openssl rand -hex 32）
# 呼叫時於 header 帶 x-admin-key: <此值>
ADMIN_API_KEY=

# 後台登入密碼；留空＝停用後台登入。建議 openssl rand -hex 24
ADMIN_PASSWORD=

# Redis（給 BullMQ / cache / rate-limit 共用）
REDIS_URL=redis://localhost:6379

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# S3 / 物件儲存（可指向 AWS S3、Cloudflare R2、MinIO）
S3_ENDPOINT=
S3_REGION=ap-northeast-1
S3_BUCKET=app-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=false

# SMTP / Mail
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="App <noreply@example.com>"

# ---- LLM provider（支援 anthropic / openai；預設 anthropic）----
# anthropic：claude-sonnet-4-5；openai：改 LLM_PROVIDER=openai、LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5
# intent-router 意圖分類器用的便宜/快模型（省 token）；openai 時改為對應便宜模型如 gpt-4o-mini
LLM_ROUTER_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=1024
# provider=anthropic 必填
ANTHROPIC_API_KEY=
# provider=openai 必填；知識庫 RAG 的 embedding 也用 OpenAI（Claude 無原生 embedding），故啟用 RAG 時必填
OPENAI_API_KEY=

# ---- 知識庫 RAG（每租戶靜態網站索引；可在 admin 後台逐租戶設定/觸發）----
# embedding 需 OPENAI_API_KEY（見上）。以下為「未設定時的預設值」，admin UI 的租戶設定會覆蓋。
# 精準度優先預設 large；要省成本改 text-embedding-3-small（改後需以相同模型重跑該租戶 ingest）
EMBEDDING_MODEL=text-embedding-3-large
# 每租戶索引檔存放目錄；檔名為 knowledge-index.<tenantId>.json
KNOWLEDGE_INDEX_DIR=data
# 兩階段檢索：向量取候選池後用 LLM_ROUTER_MODEL 重排（精準度↑，每次知識查詢多一次便宜呼叫）；設 false 關閉
KNOWLEDGE_RERANK=true

# ---- OA 連接器（stub=不接真 OA；http=接真 OA 系統）----
# 切到 http 時 OA_BASE_URL 為必填（boot 時 fail-fast 檢查）
OA_CONNECTOR=stub
# OA_BASE_URL=https://oa.example.com
# OA_API_KEY=
