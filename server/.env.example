# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app_dev?schema=public"

# JWT
JWT_ACCESS_SECRET=replace_with_strong_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_strong_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Redis（給 BullMQ / cache / rate-limit 共用）
REDIS_URL=redis://localhost:6379

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# S3 / 物件儲存（可指向 AWS S3、Cloudflare R2、MinIO）
S3_ENDPOINT=
S3_REGION=ap-northeast-1
S3_BUCKET=app-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=false

# SMTP / Mail
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="App <noreply@example.com>"

# ---- LLM provider（MVP 用 Claude）----
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5
LLM_MAX_TOKENS=1024
# 必填：放你的 Anthropic API key
ANTHROPIC_API_KEY=

# ---- OA 連接器（MVP 用 stub，不接真 OA）----
OA_CONNECTOR=stub
# OA_BASE_URL=
# OA_API_KEY=
